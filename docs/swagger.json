{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "A stateless developer toolbox providing HTTP inspection, cURL conversion, JWT toolkit, and JSON generation.",
        "title": "DevHelp API",
        "contact": {},
        "version": "1.0.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/v1/curl-converter": {
            "post": {
                "description": "Parses a cURL command and returns equivalent code in Go, Python, Java, C, C++, Ruby, JavaScript, and Kotlin.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "cURL Converter"
                ],
                "summary": "Convert a cURL command to multiple languages",
                "parameters": [
                    {
                        "description": "cURL command input",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.CurlConverterRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/dto.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/dto.CurlConverterResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/dto.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/dto.APIResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/curl-converter/languages": {
            "get": {
                "description": "Returns the list of languages the cURL Converter can generate code for.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "cURL Converter"
                ],
                "summary": "List supported languages",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.APIResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/health": {
            "get": {
                "description": "Returns the health status of the DevHelp API.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/dto.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/dto.HealthResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/api/v1/http-inspector": {
            "post": {
                "description": "Parses a raw HTTP request or cURL command and returns a detailed structural breakdown.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "HTTP Inspector"
                ],
                "summary": "Inspect an HTTP request",
                "parameters": [
                    {
                        "description": "Raw HTTP or cURL input",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.HTTPInspectorRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/dto.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/dto.HTTPInspectorResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/dto.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/dto.APIResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/json-generator": {
            "post": {
                "description": "Parses a JSON payload and returns equivalent Go struct and TypeScript interface definitions.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "JSON Generator"
                ],
                "summary": "Generate type definitions from JSON",
                "parameters": [
                    {
                        "description": "JSON generation input",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.JSONGeneratorRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/dto.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/dto.JSONGeneratorResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/dto.APIResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/jwt/decode": {
            "post": {
                "description": "Decodes a JWT and returns header, payload, signature, and time claims. Optionally verifies the signature.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "JWT Toolkit"
                ],
                "summary": "Decode a JWT",
                "parameters": [
                    {
                        "description": "JWT decode input",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.JWTDecodeRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/dto.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/dto.JWTDecodeResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/dto.APIResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/jwt/generate": {
            "post": {
                "description": "Signs and returns a new HS256 JWT with the provided claims and secret.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "JWT Toolkit"
                ],
                "summary": "Generate a JWT",
                "parameters": [
                    {
                        "description": "JWT generation input",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.JWTGenerateRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/dto.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/dto.JWTGenerateResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/dto.APIResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "dto.APIError": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "details": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "dto.APIResponse": {
            "type": "object",
            "properties": {
                "data": {},
                "error": {
                    "$ref": "#/definitions/dto.APIError"
                },
                "request_id": {
                    "type": "string"
                },
                "success": {
                    "type": "boolean"
                }
            }
        },
        "dto.AuthInfo": {
            "type": "object",
            "properties": {
                "credentials": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "dto.CurlConverterRequest": {
            "type": "object",
            "required": [
                "curl_command"
            ],
            "properties": {
                "curl_command": {
                    "description": "CurlCommand is the full cURL command string to convert.",
                    "type": "string",
                    "example": "curl -X POST https://api.example.com/data -H 'Content-Type: application/json' -d '{\"key\":\"value\"}'"
                },
                "languages": {
                    "description": "Languages lists the target languages to generate code for.\nIf empty, all supported languages are returned.",
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "[\"go\"",
                        "\"python\"]"
                    ]
                }
            }
        },
        "dto.CurlConverterResponse": {
            "type": "object",
            "properties": {
                "json": {
                    "description": "JSON is a structured representation of the parsed cURL command.",
                    "allOf": [
                        {
                            "$ref": "#/definitions/dto.ParsedCurl"
                        }
                    ]
                },
                "snippets": {
                    "description": "Snippets maps language name to generated code string.",
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                }
            }
        },
        "dto.HTTPInspectorRequest": {
            "type": "object",
            "properties": {
                "curl_command": {
                    "description": "CurlCommand is an optional cURL command string to be parsed and inspected.",
                    "type": "string",
                    "example": "curl -X POST https://api.example.com/data -H 'Content-Type: application/json' -d '{\"key\":\"value\"}'"
                },
                "raw_http": {
                    "description": "RawHTTP is an optional raw HTTP/1.1 request (e.g. \"GET /path HTTP/1.1\\r\\nHost: …\").",
                    "type": "string",
                    "example": "GET /ping?foo=bar HTTP/1.1\r\nHost: example.com\r\n\r\n"
                }
            }
        },
        "dto.HTTPInspectorResponse": {
            "type": "object",
            "properties": {
                "authorization": {
                    "$ref": "#/definitions/dto.AuthInfo"
                },
                "body": {
                    "type": "string"
                },
                "content_type": {
                    "type": "string"
                },
                "cookies": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "headers": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "method": {
                    "type": "string"
                },
                "parsed_form": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "parsed_json": {},
                "path": {
                    "type": "string"
                },
                "query_params": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "url": {
                    "type": "string"
                }
            }
        },
        "dto.HealthResponse": {
            "type": "object",
            "properties": {
                "env": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "version": {
                    "type": "string"
                }
            }
        },
        "dto.JSONGeneratorRequest": {
            "type": "object",
            "required": [
                "json"
            ],
            "properties": {
                "json": {
                    "description": "JSON is the raw JSON string to generate type definitions from.",
                    "type": "string",
                    "example": "{\"name\":\"Alice\",\"age\":30,\"address\":{\"city\":\"NYC\"}}"
                },
                "root_name": {
                    "description": "RootName is the optional name for the root type. Defaults to \"Root\".",
                    "type": "string",
                    "example": "User"
                }
            }
        },
        "dto.JSONGeneratorResponse": {
            "type": "object",
            "properties": {
                "go_struct": {
                    "description": "GoStruct is the generated Go struct definition.",
                    "type": "string"
                },
                "typescript_interface": {
                    "description": "TypeScriptInterface is the generated TypeScript interface definition.",
                    "type": "string"
                }
            }
        },
        "dto.JWTDecodeRequest": {
            "type": "object",
            "required": [
                "token"
            ],
            "properties": {
                "secret": {
                    "description": "Secret is optional. When provided the signature is verified.",
                    "type": "string"
                },
                "token": {
                    "description": "Token is the full JWT string (header.payload.signature).",
                    "type": "string"
                }
            }
        },
        "dto.JWTDecodeResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                },
                "expires_at": {
                    "type": "string"
                },
                "header": {
                    "type": "object",
                    "additionalProperties": true
                },
                "issued_at": {
                    "type": "string"
                },
                "not_before": {
                    "type": "string"
                },
                "payload": {
                    "type": "object",
                    "additionalProperties": true
                },
                "signature": {
                    "type": "string"
                },
                "valid": {
                    "type": "boolean"
                }
            }
        },
        "dto.JWTGenerateRequest": {
            "type": "object",
            "required": [
                "claims",
                "secret"
            ],
            "properties": {
                "claims": {
                    "description": "Claims are the custom payload claims to embed in the token.",
                    "type": "object",
                    "additionalProperties": true
                },
                "expires_in_seconds": {
                    "description": "ExpiresInSeconds is the token TTL in seconds. Defaults to 3600 if zero.",
                    "type": "integer",
                    "example": 3600
                },
                "secret": {
                    "description": "Secret is the HMAC-SHA256 signing key.",
                    "type": "string",
                    "example": "my-super-secret"
                }
            }
        },
        "dto.JWTGenerateResponse": {
            "type": "object",
            "properties": {
                "token": {
                    "type": "string"
                }
            }
        },
        "dto.ParsedCurl": {
            "type": "object",
            "properties": {
                "body": {
                    "type": "string"
                },
                "headers": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "method": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                }
            }
        }
    }
}